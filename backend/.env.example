# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- Database ---
DATABASE_URL=postgresql+pg8000://pulse_user:pulse_password@localhost:5432/pulse_db

# --- JWT Auth ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- LLM API Keys ---
# Get Gemini free tier key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get Groq free tier key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Storage ---
UPLOAD_DIR=uploads

# --- Environment ---
ENVIRONMENT=development   # development | production
